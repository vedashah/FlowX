#!/usr/bin/env python3
"""
Read and display telemetry data from Pixhawk to Raspberry Pi using MAVLink.
Tested with pymavlink on Python 3.
"""

from pymavlink import mavutil
import sys
import time

# -----------------------------
# USER CONFIGURATION
# -----------------------------
# For USB connection (Pixhawk via USB cable):
# SERIAL_PORT = '/dev/ttyACM0'
# For UART (e.g., TELEM2 port on Pixhawk to Pi GPIO UART):
# SERIAL_PORT = '/dev/serial0'
SERIAL_PORT = '/dev/ttyACM0'
BAUD_RATE = 57600  # Common for TELEM ports; USB often uses 115200

def connect_pixhawk():
    """Establish MAVLink connection to Pixhawk."""
    try:
        master = mavutil.mavlink_connection(SERIAL_PORT, baud=BAUD_RATE)
        print(f"Connecting to Pixhawk on {SERIAL_PORT} at {BAUD_RATE} baud...")
        master.wait_heartbeat()
        print(f"Heartbeat from system (system {master.target_system} component {master.target_component})")
        return master
    except Exception as e:
        print(f"Connection error: {e}")
        sys.exit(1)

def read_telemetry(master):
    """Continuously read and display telemetry data."""
    while True:
        try:
            # Wait for the next MAVLink message
            msg = master.recv_match(blocking=True)
            if not msg:
                continue

            msg_type = msg.get_type()

            if msg_type == "ATTITUDE":
                print(f"[ATTITUDE] Roll: {msg.roll:.2f} rad, Pitch: {msg.pitch:.2f} rad, Yaw: {msg.yaw:.2f} rad")

            elif msg_type == "RAW_IMU":
                print(f"[IMU] Accel: ({msg.xacc}, {msg.yacc}, {msg.zacc}) mg | Gyro: ({msg.xgyro}, {msg.ygyro}, {msg.zgyro}) mrad/s")

            elif msg_type == "GLOBAL_POSITION_INT":
                lat = msg.lat / 1e7
                lon = msg.lon / 1e7
                alt = msg.alt / 1000.0
                print(f"[GPS] Lat: {lat:.7f}, Lon: {lon:.7f}, Alt: {alt:.2f} m")

            elif msg_type == "SYS_STATUS":
                voltage = msg.voltage_battery / 1000.0
                current = msg.current_battery / 100.0
                print(f"[BATTERY] Voltage: {voltage:.2f} V, Current: {current:.2f} A, Remaining: {msg.battery_remaining}%")

        except KeyboardInterrupt:
            print("\nTelemetry reading stopped.")
            break
        except Exception as e:
            print(f"Error reading telemetry: {e}")
            time.sleep(1)

if __name__ == "__main__":
    master_conn = connect_pixhawk()
    read_telemetry(master_conn)
